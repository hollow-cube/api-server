package components

templ Layout(title string) {
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <title>{ title }</title>
        <link href="/static/styles.css" rel="stylesheet"/>
    </head>
    <body class="min-h-screen bg-background text-foreground">
        { children... }
    </body>
    </html>
}
